# ==============================================================================
# API BLACKBOX CONFIGURATION
# Copy this file to .env and fill out the API keys for the providers you want to use.
# BlackBox will automatically skip any providers with missing or dead keys.
# ==============================================================================

# 1. Cloudflare Workers AI (Fastest / Recommended)
# Get your API Token & Account ID here: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# 2. Mistral API
# Get your API key here: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# 3. Groq API (Incredibly fast Llama 3)
# Get your API key here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# 4. Cerebras API (Ultra fast inference)
# Get your API key here: https://inference.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# 5. OpenRouter API (Access to hundreds of models)
# Get your API key here: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 6. GitHub Models API
# Get your GitHub Personal Access Token here: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# 7. NVIDIA NIM API
# Get your API key here: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# 8. HuggingFace Serverless Inference API
# Get your API key here: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# 9. Google Gemini API
# Get your API key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 10. OpenAI API
# Get your API key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# ⚠️ THE PROVIDERS BELOW RARELY WORK AND FREQUENTLY HAVE ISSUES ⚠️
# ==============================================================================

# 11. Zhipu AI (GLM-4)
# Get your API key here: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# 12. Cohere API
# Get your API key here: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here
